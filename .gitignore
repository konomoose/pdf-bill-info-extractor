# Python virtual environments
.venv/
venv/

# Python-generated files
__pycache__/
*.py[cod]
.pytest_cache/

# Institution source statements
input/**/*
!input/**/
!input/**/.gitkeep

# Generated extraction output
output/**/*
!output/**/
!output/**/.gitkeep

# Local regression-test statements
tests/input/**/*
!tests/input/**/
!tests/input/**/.gitkeep

# Manually verified reference CSV files
tests/reference_output/**/*
!tests/reference_output/**/
!tests/reference_output/**/.gitkeep

# Output created by automated tests
tests/output/**/*
!tests/output/**/
!tests/output/**/.gitkeep

# Ghostscript installer
ghostscript-gs*.exe

# Logs and temporary files
*.log
temp/
tmp/

# Local configuration overrides
.env
config/*.local.json
config/profiles/*.local.json

# Editors and Windows files
.vscode/
.idea/
Thumbs.db
desktop.ini
